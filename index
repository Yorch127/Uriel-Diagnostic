<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>J&J Texas Lone Star AutoDiag — 2010 Chevrolet Silverado 1500</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Barlow', sans-serif; background: #f0f0f0; color: #1a1a1a; min-height: 100vh; }

/* HEADER */
.header { background: #111; padding: 18px 20px 18px; }
.header-top { display: flex; align-items: center; gap: 14px; }
.logo-box {
  background: #fff; border-radius: 10px; padding: 6px;
  flex-shrink: 0; width: 68px; height: 68px;
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.logo-box img { width: 56px; height: 56px; object-fit: cover; border-radius: 6px; }
.header-title { flex: 1; }
.header-title h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px; font-weight: 700; color: #fff;
  letter-spacing: 0.5px; line-height: 1.1;
}
.header-title h1 span { color: #C8962E; }
.header-title p {
  font-size: 11px; font-weight: 600; letter-spacing: 2.5px;
  text-transform: uppercase; color: #888; margin-top: 3px;
}

/* VEHICLE HERO */
.vehicle-hero { position: relative; width: 100%; overflow: hidden; max-height: 340px; }
.vehicle-hero img {
  width: 100%; max-height: 340px;
  object-fit: cover; object-position: center 40%; display: block;
}
.hero-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.35) 65%, transparent 100%);
  padding: 22px 18px 16px;
}
.hero-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 34px; font-weight: 800; color: #fff;
  text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  margin-bottom: 10px; line-height: 1;
}
.spec-pills { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 10px; }
.pill {
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255,255,255,0.25);
  color: #fff; font-size: 12px; font-weight: 600;
  padding: 5px 11px; border-radius: 20px; letter-spacing: 0.3px;
}
.status-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.status-badge {
  font-size: 13px; font-weight: 700;
  padding: 5px 13px; border-radius: 5px; letter-spacing: 0.3px;
}
.status-red { background: #CC1B1B; color: #fff; }
.status-gold { background: #C8962E; color: #fff; }

/* INFO CARD */
.info-card {
  background: #fff; border-radius: 14px;
  margin: 16px 12px; padding: 6px 0;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
}
.info-row {
  display: grid; grid-template-columns: 1fr 1fr;
  border-bottom: 1px solid #f0f0f0;
}
.info-row:last-child { border-bottom: none; }
.info-cell { padding: 14px 18px; }
.info-cell:first-child { border-right: 1px solid #f0f0f0; }
.info-label {
  font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: #bbb; line-height: 1.3; margin-bottom: 6px;
}
.info-label span { display: block; }
.info-value { font-size: 16px; font-weight: 600; color: #1a1a1a; line-height: 1.2; }

/* SECTION CARD */
.section-card {
  background: #fff; border-radius: 14px;
  margin: 0 12px 16px; overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
}
.section-header {
  background: #111; padding: 12px 18px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; color: #C8962E;
}

/* SERVICE TABLE */
.svc-table { width: 100%; border-collapse: collapse; }
.svc-table thead tr { background: #f7f7f7; }
.svc-table thead th {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
  color: #aaa; padding: 9px 16px; text-align: left; font-weight: 700;
}
.svc-table thead th.r { text-align: right; }
.svc-table tbody tr { border-bottom: 1px solid #f5f5f5; }
.svc-table tbody td { padding: 12px 16px; font-size: 13px; color: #333; vertical-align: top; }
.svc-table tbody td.price { text-align: right; font-weight: 700; color: #111; white-space: nowrap; }
.svc-name { font-weight: 600; color: #111; margin-bottom: 2px; font-size: 13px; }
.svc-sub { font-size: 11.5px; color: #999; line-height: 1.5; }
.opt-hdr td {
  background: #f9f9f9 !important;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase;
  color: #888; font-weight: 700; padding: 8px 16px;
}
.opt-a td { border-left: 3px solid #2563eb; }
.opt-b td { border-left: 3px solid #16a34a; }
.badge {
  display: inline-block; font-size: 9px; font-weight: 700;
  padding: 2px 7px; border-radius: 10px; text-transform: uppercase;
  margin-left: 6px; vertical-align: middle;
}
.ba { background: #dbeafe; color: #1d4ed8; }
.bb { background: #dcfce7; color: #15803d; }
.disc td { color: #16a34a !important; font-style: italic; }
.disc .price { color: #16a34a !important; }

/* TOTALS */
.totals-wrap { padding: 14px 16px; }
.tot-box {
  background: #f7f7f7; border-radius: 10px;
  padding: 14px 16px; margin-bottom: 10px; border: 1px solid #eee;
}
.tot-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; margin-bottom: 10px;
}
.tot-title.a { color: #2563eb; }
.tot-title.b { color: #16a34a; }
.tot-row {
  display: flex; justify-content: space-between;
  font-size: 13px; padding: 3px 0; border-bottom: 1px solid #ececec;
}
.tot-row .tl { color: #888; }
.tot-row .tv { font-weight: 600; color: #111; }
.tot-note { font-size: 11px; color: #ccc; font-style: italic; padding: 4px 0 2px; }
.tot-final {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 30px; font-weight: 800; color: #111; line-height: 1; margin-top: 6px;
}
.tot-sub { font-size: 11px; color: #aaa; }

/* NOTES */
.notes-list { padding: 14px 18px; font-size: 13px; color: #555; line-height: 1.8; }
.notes-list li { margin-left: 16px; margin-bottom: 4px; }

/* FOOTER */
.footer { background: #111; padding: 20px; text-align: center; margin-top: 8px; }
.footer-logo {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 16px; font-weight: 800; color: #fff; letter-spacing: 1px; margin-bottom: 6px;
}
.footer-logo span { color: #C8962E; }
.footer-info { font-size: 12px; color: #666; line-height: 1.8; }
.footer-info a { color: #C8962E; text-decoration: none; }

@media (max-width: 480px) {
  .hero-title { font-size: 26px; }
  .info-value { font-size: 15px; }
  .svc-table thead th:nth-child(2), .svc-table tbody td:nth-child(2) { display: none; }
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-top">
    <div class="logo-box">
      <img src="data:image/jpeg;base64," alt="J&J Texas Lone Star">
    </div>
    <div class="header-title">
      <h1>J&amp;J Texas Lone Star <span>AutoDiag</span></h1>
      <p>Vehicle Service Record</p>
    </div>
  </div>
</div>

<!-- VEHICLE HERO -->
<div class="vehicle-hero">
  <img src="data:image/jpeg;base64," alt="2010 Chevrolet Silverado 1500">
  <div class="hero-overlay">
    <div class="hero-title">2010 Chevrolet Silverado 1500</div>
    <div class="spec-pills">
      <span class="pill">5.3L V8</span>
      <span class="pill">Extended Cab</span>
      <span class="pill">4WD</span>
      <span class="pill">TX LKZ-7990</span>
    </div>
    <div class="status-row">
      <span class="status-badge status-red">Throttle Body &amp; Transmission</span>
      <span class="status-badge status-gold">Service Record</span>
    </div>
  </div>
</div>

<!-- INFO CARD -->
<div class="info-card">
  <div class="info-row">
    <div class="info-cell">
      <div class="info-label"><span>DATE</span><span>FECHA</span></div>
      <div class="info-value">May 16, 2026</div>
    </div>
    <div class="info-cell">
      <div class="info-label"><span>ENGINE</span><span>MOTOR</span></div>
      <div class="info-value">5.3L V8 Vortec</div>
    </div>
  </div>
  <div class="info-row">
    <div class="info-cell">
      <div class="info-label"><span>CUSTOMER</span><span>CLIENTE</span></div>
      <div class="info-value">Erick Uriel Nu&ntilde;ez</div>
    </div>
    <div class="info-cell">
      <div class="info-label"><span>TECHNICIAN</span><span>T&Eacute;CNICO</span></div>
      <div class="info-value">Jorge Vasquez</div>
    </div>
  </div>
  <div class="info-row">
    <div class="info-cell">
      <div class="info-label"><span>PLATE</span><span>PLACA</span></div>
      <div class="info-value">TX LKZ-7990</div>
    </div>
    <div class="info-cell">
      <div class="info-label"><span>VIN</span></div>
      <div class="info-value" style="font-size:13px;letter-spacing:0.5px;">1G1G8REA2AZ179323</div>
    </div>
  </div>
</div>

<!-- SERVICE ESTIMATE -->
<div class="section-card">
  <div class="section-header">Service Estimate</div>
  <table class="svc-table">
    <thead>
      <tr>
        <th style="width:40%">Service / Part</th>
        <th style="width:35%">Description</th>
        <th class="r" style="width:25%">Price</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          <div class="svc-name">Throttle Body Replacement</div>
          <div class="svc-sub">Ultima Tech ETB2006<br>Limited Lifetime Warranty</div>
        </td>
        <td><div class="svc-sub">Replace electronic throttle body, includes installation &amp; relearn procedure.</div></td>
        <td class="price">$289.00</td>
      </tr>
      <tr class="opt-hdr">
        <td colspan="3">Transmission Repair — Customer Selects One Option</td>
      </tr>
      <tr class="opt-a">
        <td>
          <div class="svc-name">Option A — Used Transmission <span class="badge ba">Junkyard</span></div>
          <div class="svc-sub">Pre-owned salvage unit. No rebuild warranty.</div>
        </td>
        <td><div class="svc-sub">Remove &amp; replace with used salvage unit. Lower cost option.</div></td>
        <td class="price">$2,000.00</td>
      </tr>
      <tr class="opt-b">
        <td>
          <div class="svc-name">Option B — Rebuilt Transmission <span class="badge bb">Recommended</span></div>
          <div class="svc-sub">Professionally rebuilt with fresh internals &amp; seals.</div>
        </td>
        <td><div class="svc-sub">Remove &amp; replace with fully rebuilt unit. Better long-term reliability.</div></td>
        <td class="price">$2,500.00</td>
      </tr>
      <tr>
        <td>
          <div class="svc-name">Labor</div>
          <div class="svc-sub">Transmission R&amp;R + Throttle Body Installation</div>
        </td>
        <td><div class="svc-sub">Complete labor for all repairs listed above.</div></td>
        <td class="price">$850.00</td>
      </tr>
      <tr class="disc">
        <td>
          <div class="svc-name">Labor Discount</div>
          <div class="svc-sub">Courtesy discount applied</div>
        </td>
        <td><div class="svc-sub">Customer discount on labor.</div></td>
        <td class="price">&minus; $200.00</td>
      </tr>
    </tbody>
  </table>
</div>

<!-- TOTALS -->
<div class="section-card">
  <div class="section-header">Quote Totals</div>
  <div class="totals-wrap">
    <div class="tot-box">
      <div class="tot-title a">Option A — Junkyard Transmission</div>
      <div class="tot-row"><span class="tl">Throttle Body</span><span class="tv">$289.00</span></div>
      <div class="tot-row"><span class="tl">Used Transmission</span><span class="tv">$2,000.00</span></div>
      <div class="tot-row"><span class="tl">Labor (after discount)</span><span class="tv">$650.00</span></div>
      <div class="tot-note">+ applicable sales tax not included</div>
      <div class="tot-final">$2,939.00</div>
      <div class="tot-sub">Before Tax</div>
    </div>
    <div class="tot-box">
      <div class="tot-title b">Option B — Rebuilt Transmission</div>
      <div class="tot-row"><span class="tl">Throttle Body</span><span class="tv">$289.00</span></div>
      <div class="tot-row"><span class="tl">Rebuilt Transmission</span><span class="tv">$2,500.00</span></div>
      <div class="tot-row"><span class="tl">Labor (after discount)</span><span class="tv">$650.00</span></div>
      <div class="tot-note">+ applicable sales tax not included</div>
      <div class="tot-final">$3,439.00</div>
      <div class="tot-sub">Before Tax</div>
    </div>
  </div>
</div>

<!-- NOTES -->
<div class="section-card">
  <div class="section-header">Important Notes</div>
  <ul class="notes-list">
    <li>This is an estimate only. Final price may vary upon further inspection.</li>
    <li>Customer must select a transmission option before work begins.</li>
    <li>Throttle body (ETB2006) carries a Limited Lifetime Warranty through Ultima Technologies.</li>
    <li>Tax not included. Applicable taxes will be added at final invoicing.</li>
    <li>Quote valid for 30 days from date of issue.</li>
  </ul>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-logo">J&amp;J TEXAS <span>LONE STAR</span></div>
  <div class="footer-info">
    10107 Crammond St, Houston TX 77064<br>
    (832) 807-0449 &nbsp;&middot;&nbsp; <a href="http://jjtexaslonestar.com">jjtexaslonestar.com</a>
  </div>
</div>

</body>
</html>
